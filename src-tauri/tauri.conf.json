{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "productName": "tauri-desktop-HUD",
  "version": "0.1.0",
  "identifier": "tauri-hud.prototype.codemonkeyninja.dev",
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "tauri-desktop-HUD",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["shell:open"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
