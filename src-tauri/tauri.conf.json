{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "tauri-desktop-HUD",
  "version": "0.1.0",
  "identifier": "com.hidekiai.desktop-hud",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tauri Desktop HUD",
        "width": 800,
        "height": 200,
        "transparent": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
