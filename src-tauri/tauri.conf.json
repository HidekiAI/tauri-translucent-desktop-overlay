{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "tauri-desktop-HUD",
  "version": "0.1.0",
  "identifier": "com.hidekiai.desktop-hud",
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri Desktop HUD - Web Content Renderer",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
